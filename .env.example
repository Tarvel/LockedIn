# =============================================================================
# LockedIn — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in your values.
# For local development, all values have sensible defaults — you can run
# the app without setting any of these.

# ── Django ───────────────────────────────────────────────────────────────────
# Secret key for cryptographic signing. Generate one at:
# https://djecrety.ir/
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key

# Set to False in production
DEBUG=True

# ── Database ─────────────────────────────────────────────────────────────────
# Omit this to use SQLite (default for local dev).
# For production (Vercel/Neon), use a PostgreSQL connection string:
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ── AI Pipeline ──────────────────────────────────────────────────────────────
# URL of the AI roadmap generation API (e.g. HuggingFace Spaces endpoint).
# Without this, the app uses demo/placeholder roadmap data.
AI_API_URL=https://your-api-endpoint.com
